<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Held by LocationForegroundService (collection) and TrackingAlarmReceiver (handoff). A
         battery-optimization-exempt app may hold a PARTIAL_WAKE_LOCK during Doze, which is what
         keeps the CPU awake to collect GPS overnight while the phone is locked. Previously only
         merged transitively from WorkManager/Play Services — declared explicitly so the core
         Doze-survival path never depends on a dependency contributing it. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Exact alarm to open the tracking window precisely while the device is in Deep Doze.
         setExactAndAllowWhileIdle requires this; on Android 12+ it can be revoked by the user, so
         TrackingAlarmScheduler checks canScheduleExactAlarms() and falls back to an inexact Doze
         alarm if it is not granted. (USE_EXACT_ALARM is the always-granted alternative but Google
         Play restricts it to alarm-clock/calendar apps, so we use SCHEDULE_EXACT_ALARM here.) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Play-policy-compliant package visibility (replaces QUERY_ALL_PACKAGES, which is restricted
         to launchers/antivirus/etc. and would fail Play review for this app). Only the packages
         named here are visible to PackageManager lookups; every other lookup behaves as
         "not installed". Two consumer groups:
           1. App-presence monitoring (AppMonitoringRepositoryImpl): each backend app id is mapped
              to one of these packages. Adding a new monitored app requires BOTH a new <package>
              entry here AND a KNOWN_APP_PACKAGES map entry.
           2. OEM auto-start / battery-manager settings screens that the permission wizard
              deep-links into (OemProfile). Without visibility, resolveActivity() returns null and
              the wizard would silently fall back to the generic App Info page on those devices. -->
    <queries>
        <!-- Monitored apps -->
        <package android:name="org.telegram.messenger" />
        <package android:name="us.zoom.videomeetings" />
        <!-- OEM settings packages (permission wizard deep links) -->
        <package android:name="com.miui.securitycenter" />
        <package android:name="com.iqoo.secure" />
        <package android:name="com.vivo.permissionmanager" />
        <package android:name="com.coloros.safeguard" />
        <package android:name="com.coloros.oppoguardelf" />
        <package android:name="com.oneplus.security" />
        <package android:name="com.samsung.android.lool" />
    </queries>

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".YourswelnesApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Yourswelnes">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Yourswelnes">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".core.service.LocationForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Tell FCM SDK which channel to use for system-tray notifications when the app is
             in background or killed. Without this, FCM creates a "Miscellaneous" channel
             with IMPORTANCE_DEFAULT — no heads-up, no sound. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="yw_notifications" />

        <service
            android:name=".core.notification.YwFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".core.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Fired only by our own exact-alarm PendingIntent (TrackingAlarmScheduler), so it is not
             exported. On receipt it grabs a partial wake lock and starts LocationForegroundService
             to survive Deep Doze at the window start. -->
        <receiver
            android:name=".core.receiver.TrackingAlarmReceiver"
            android:exported="false" />

        <!-- Disable WorkManager's default ContentProvider initializer so HiltWorkerFactory is used -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
    </application>

</manifest>
